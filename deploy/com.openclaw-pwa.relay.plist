<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.openclaw-pwa.relay</string>

    <key>Comment</key>
    <string>OpenClaw PWA Relay Server</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/m4-mac/openclaw-pwa</string>

    <key>ProgramArguments</key>
    <array>
      <string>/opt/homebrew/bin/node</string>
      <string>/Users/m4-mac/openclaw-pwa/server/index.js</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/m4-mac/.openclaw/logs/pwa-relay.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/m4-mac/.openclaw/logs/pwa-relay.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>/Users/m4-mac</string>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
  </dict>
</plist>
