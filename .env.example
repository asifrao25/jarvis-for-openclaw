# Copy this file to .env and fill in your values

# Required: Password for connecting to OpenClaw gateway
GATEWAY_PASSWORD=your_gateway_password_here

# Required: Email for VAPID push notifications
VAPID_EMAIL=mailto:your-email@example.com

# Optional: Tailscale hostname for PWA access
TAILSCALE_HOST=your-machine.tailxxxxx.ts.net

# Optional: Moonshot AI API key for displaying balance
MOONSHOT_API_KEY=sk-your-moonshot-api-key

# Optional: Local health checker (Qwen2.5 via Ollama)
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:1.5b
# HEALTH_CHECK_INTERVAL_MS=60000
# HEALTH_CHECK_TIMEOUT_MS=10000
